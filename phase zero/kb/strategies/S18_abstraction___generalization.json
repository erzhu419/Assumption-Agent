{
  "id": "S18",
  "name": {
    "zh": "抽象化/泛化",
    "en": "Abstraction / Generalization"
  },
  "aliases": [
    "泛化",
    "模式识别",
    "结构提取",
    "概念化"
  ],
  "category": "reasoning",
  "source_references": [
    {
      "author": "Polya, G.",
      "work": "How to Solve It",
      "year": 1945,
      "chapter": "Looking Back",
      "relevance": "将问题泛化为更一般的问题是波利亚问题解决策略的核心启发式之一。"
    },
    {
      "author": "Mac Lane, S.",
      "work": "Categories for the Working Mathematician",
      "year": 1971,
      "chapter": null,
      "relevance": "范畴论为数学中的抽象化和泛化提供了严格的数学基础，通过函子等概念描述结构保持的映射。"
    }
  ],
  "description": {
    "one_sentence": "去掉具体细节，提取问题的抽象结构",
    "detailed": "抽象化/泛化是一种认知策略，旨在通过识别并聚焦于多个具体实例、问题或现象之间的共同属性、关系、模式或结构，从而构建一个更普遍、更简洁的概念、模型或理论。此过程有意识地忽略那些被认为是无关紧要或特定于某个实例的细节，以揭示深层原理或普适规律。其核心目的是简化复杂性，提高理解效率，并使解决方案或理论能够应用于更广泛的场景。",
    "intuitive_analogy": "想象你正在观察一片森林里的各种树木：高大的橡树、笔直的松树、弯曲的柳树。抽象化/泛化就像你忽略了它们具体的树叶形状、树皮颜色、高度等细节，而总结出“树”这个概念，只保留了“有根、有茎、有枝、能光合作用”等核心特征。这个“树”的概念可以适用于所有你见过的和未见过的树木。"
  },
  "operational_steps": [
    {
      "step": 1,
      "action": "识别并收集多个具体实例：从问题域中收集多个看似不同但可能相关的具体问题、数据点、现象或案例。",
      "on_difficulty": "如果实例不足或不明确，递归调用 S01 (信息收集) 或 S05 (案例分析) 来获取更多相关信息。"
    },
    {
      "step": 2,
      "action": "比较与分析实例，识别共同特征与差异：对收集到的实例进行比较，找出它们之间共享的属性、关系、模式或结构，并区分出哪些是核心的、普遍的，哪些是偶然的、特定的细节。",
      "on_difficulty": "如果难以识别共同特征或区分核心与细节，尝试 S03 (比较与对比) 或 S04 (特征工程) 来辅助分析。"
    },
    {
      "step": 3,
      "action": "剔除无关细节，聚焦核心结构：有意识地忽略那些在不同实例中变化、对问题核心不重要或被认为是偶然的具体信息，只保留那些被识别为共同且关键的特征。",
      "on_difficulty": "如果不确定哪些细节是无关的，尝试 S06 (敏感性分析) 或 S07 (因果推断) 来评估细节对问题解决的重要性。"
    },
    {
      "step": 4,
      "action": "构建抽象模型、概念或理论：基于保留的核心特征和结构，形成一个更普遍、更抽象的表示、模型、概念或理论，它能够简洁地涵盖所有原始实例，并解释其共同行为或性质。",
      "on_difficulty": "如果构建的模型过于复杂、不一致或无法有效解释所有实例，尝试 S08 (模型简化) 或 S09 (迭代优化) 来改进抽象模型。"
    },
    {
      "step": 5,
      "action": "验证与应用抽象模型：检查抽象模型是否能成功地解释或解决原始问题，并尝试将其应用于新的、未见的类似问题，以验证其普适性和预测能力。",
      "on_difficulty": "如果模型验证失败或在新问题上表现不佳，返回步骤2或3，重新评估特征和细节的取舍，或调整抽象层次。"
    }
  ],
