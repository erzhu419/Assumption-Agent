{
  "id": "S22",
  "name": {
    "zh": "问题重构",
    "en": "Problem Reframing"
  },
  "aliases": [
    "重新定义问题",
    "换框思考",
    "范式转换"
  ],
  "category": "meta_decision",
  "form": "canonical_orientation",
  "source": {
    "author": "Polya, George",
    "work": "How to Solve It",
    "year": 1945,
    "section": "First Main Part: 'Restate the problem' / 'Variation of the problem'"
  },
  "description": {
    "one_sentence": "不在当前框架内继续尝试，而是重新定义问题本身",
    "background": "问题重构是一种元认知策略，它认识到在当前问题框架下无法找到有效解决方案时，通过质疑并改变对问题的基本假设、边界、目标或视角来重新定义问题。这通常涉及跳出现有的思维定势，从一个全新的角度审视问题，从而开启新的解决路径。它强调的不是在给定框架内寻找答案，而是改变框架本身，以期发现更深层次的原因或更有效的解决方案。"
  },
  "heuristic_questions_en": [
    "Can you restate the problem?",
    "Can you restate it in a different way?",
    "Can you restate it in your own words?",
    "Can you imagine a more accessible related problem?",
    "Can you vary the problem?",
    "Can you change the data or the unknown, or both if necessary, so that the new unknown and the new data are nearer to each other?"
  ],
  "heuristic_questions_zh": [
    "你能重述这个问题吗？",
    "你能用不同的方式重述它吗？",
    "你能用你自己的话重述它吗？",
    "你能想象一个更容易解决的相关问题吗？",
    "你能改变这个问题吗？",
    "你能改变已知条件或未知数，或者在必要时两者都改变，使得新的未知数和新的已知条件彼此更接近吗？"
  ],
  "fidelity_note": "前三条是 Polya 在 'Restate the problem' 部分的典型问句，后三条是 'Variation of the problem' 部分的典型问句，尽可能还原原文。",
  "original_source_references": [
    {
      "author": "Kuhn, T. S.",
      "work": "The Structure of Scientific Revolutions",
      "year": 1962,
      "chapter": "所有章节",
      "relevance": "提供了范式转换的概念基础，即当旧框架无法解释新现象时，需要全新的理论框架来重构问题和解决方案。"
    },
    {
      "author": "Polya, G.",
      "work": "How to Solve It",
      "year": 1945,
      "chapter": "Look at the unknown; Can you imagine a more accessible related problem?",
      "relevance": "强调了在问题解决过程中，通过改变问题表述、寻找相关问题或简化问题来获得新视角的启发式方法。"
    }
  ],
