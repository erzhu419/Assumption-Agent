{
  "id": "S13",
  "name": {
    "zh": "证伪优先",
    "en": "Falsification First"
  },
  "aliases": [
    "波普尔证伪主义",
    "反证法优先",
    "批判理性主义方法"
  ],
  "category": "empirical_testing",
  "form": "canonical_orientation",
  "source": {
    "author": "Popper, Karl R.",
    "work": "The Logic of Scientific Discovery",
    "year": 1959,
    "section": "§6 Falsifiability as criterion of demarcation"
  },
  "description": {
    "one_sentence": "优先寻找能推翻当前假设的证据，而非确认它",
    "background": "证伪优先策略强调科学探究应主动寻求能够驳倒或推翻现有理论或假设的证据，而非仅仅寻找支持性证据。其核心思想是，一个真正的科学理论必须是可证伪的，即存在某种潜在的观察或实验结果能够证明其为假。通过系统地尝试证伪，科学家能够更有效地识别并淘汰错误的理论，从而推动知识的进步。这种方法旨在避免确认偏误，并确保理论的经验基础。"
  },
  "heuristic_questions_en": [
    "What observations, if found, would refute my theory?",
    "Under what conditions would I be prepared to abandon my hypothesis?",
    "What are the 'forbidden' occurrences that my theory predicts cannot happen?",
    "Can I conceive of a crucial experiment that could falsify my theory?",
    "What is the boldest, most testable prediction my theory makes?",
    "How can I expose my theory to the severest possible tests?"
  ],
  "heuristic_questions_zh": [
    "如果发现什么观察结果，会驳斥我的理论？",
    "在什么条件下，我准备放弃我的假设？",
    "我的理论预测哪些‘被禁止的’事件不可能发生？",
    "我能否构思一个关键实验，能够证伪我的理论？",
    "我的理论做出的最大胆、最可检验的预测是什么？",
    "我如何才能让我的理论经受最严峻的可能检验？"
  ],
  "fidelity_note": "前三条是原文的近似重构，后三条是Popper思想的典型表达，非常接近其原意和常用语。",
