{
  "id": "S02",
  "name": {
    "zh": "分而治之",
    "en": "Divide and Conquer"
  },
  "aliases": [
    "分治法",
    "分解与合并",
    "分解策略"
  ],
  "category": "decomposition",
  "form": "canonical_orientation",
  "source": {
    "author": "Polya, George",
    "work": "How to Solve It",
    "year": 1945,
    "section": "Second Main Part (heuristic dictionary): 'Decomposing and recombining'"
  },
  "description": {
    "one_sentence": "将复杂问题分解为可独立解决的子问题",
    "background": "分而治之是一种强大的问题解决范式，其核心思想是将一个难以直接解决的复杂问题，递归地分解为两个或多个相同或相似的、规模更小的子问题，直到子问题足够简单可以直接解决。然后，将这些子问题的解组合起来，形成原问题的解。这个过程通常包含三个主要阶段：分解（Divide，将问题拆分）、解决（Conquer，递归解决子问题）和合并（Combine，将子问题的解整合）。"
  },
  "heuristic_questions_en": [
    "Can you decompose the problem?",
    "Can you separate the problem into parts?",
    "Can you solve a part of the problem?",
    "Can you find a part of the problem that is easier to solve?",
    "Can you combine the solutions of the parts?"
  ],
  "heuristic_questions_zh": [
    "你能分解这个问题吗？",
    "你能把问题分成几部分吗？",
    "你能解决问题的一部分吗？",
    "你能找到问题中更容易解决的一部分吗？",
    "你能把各部分的解组合起来吗？"
  ],
  "fidelity_note": "所有问句都是对 Polya 'Decomposing and recombining' 章节核心思想的 approximate reconstruction，而非 verbatim 摘录。Polya 在该章节中更多是描述性地阐述分解和重组的策略，而非直接给出这些问句。",
  "original_source_references": [
    {
