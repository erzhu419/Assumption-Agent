  "category": "decomposition",
  "form": "orientation",
  "source_references": [
    {
      "author": "Polya, George",
      "work": "How to Solve It: A New Aspect of Mathematical Method",
      "year": 1945,
      "chapter": "Chapter 2: How to Solve It",
      "relevance": "提出了将复杂问题分解为更小、更易管理的部分的通用启发式方法，是分而治之思想的哲学基础。"
    },
    {
      "author": "Knuth, Donald E.",
      "work": "The Art of Computer Programming, Vol. 3: Sorting and Searching",
      "year": 1973,
      "chapter": "5.2.4 Merging, 5.2.5 Sorting by Merging, 5.2.2 Partitioning",
      "relevance": "在算法领域对分而治之策略进行了系统性的形式化和应用，如归并排序、快速排序和二分查找等。"
    }
  ],
  "description": {
    "one_sentence": "训练自己在面对复杂问题时自动反问'它的自然裂缝在哪里'",
    "background": "分而治之是一种强大的问题解决范式，其核心思想是将一个难以直接解决的复杂问题，递归地分解为两个或多个相同或相似的、规模更小的子问题，直到子问题足够简单可以直接解决。然后，将这些子问题的解组合起来，形成原问题的解。这个过程通常包含三个主要阶段：分解（Divide，将问题拆分）、解决（Conquer，递归解决子问题）和合并（Combine，将子问题的解整合）。",
    "intuitive_analogy": "想象你要吃掉一头大象。你不能一口吞下，但你可以把它切成许多小块，每一小块都可以轻松吃掉。吃完所有小块后，你就吃掉了整头大象。这里的“切块”是分解，“吃掉小块”是解决，“吃完所有小块”是合并。"
  },
  "trigger": "每当感觉问题'太大'、思绪被淹没时启动 — 不是先动手，先问分解",
  "attention_priors": [
    "这个问题天然的'接缝'在哪里？沿着哪条线切它，子问题才真正独立？",
    "如果我只解决一半，剩下的一半会不会自动浮现？",
    "我倾向于用'大力出奇迹'处理这题吗？那是信号 —— 该退一步找接缝"
  ],
  "original_wisdom": [
    {
      "source": "Polya 1945 'How to Solve It'",
      "text": "If you can't solve a problem, then there is an easier problem you can solve: find it. Could you solve a part of the problem?"
    }
  ],
