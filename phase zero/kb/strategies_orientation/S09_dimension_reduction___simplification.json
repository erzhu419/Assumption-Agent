  "historical_cases": {
    "successes": [
      {
        "case_id": "S09_SUC_001",
        "domain": "物理学",
        "case": "理想气体模型",
        "description": "在研究气体行为时，物理学家首先构建了理想气体模型，假设气体分子是无体积的质点，分子间无相互作用力，且碰撞是完全弹性的。这极大地简化了真实气体的复杂性，使得可以用简单的方程（理想气体状态方程）来描述其宏观行为。",
        "why_this_strategy_worked": "真实气体行为复杂，涉及分子间相互作用、分子体积等。通过简化这些因素，模型捕捉了气体宏观行为的核心规律，为后续研究真实气体提供了基础。",
        "demonstrates_conditions": [
          "S09_F_001",
          "S09_F_002",
          "S09_F_003"
        ]
      },
      {
        "case_id": "S09_SUC_002",
        "domain": "软件工程",
        "case": "最小可行产品 (MVP)",
        "description": "在软件开发中，MVP策略要求团队首先发布一个只包含核心功能的产品版本，以最小的投入快速验证市场需求和用户反馈。这避免了在开发完整产品上投入大量资源却发现市场不买账的风险。",
        "why_this_strategy_worked": "完整产品开发周期长、风险高。通过简化产品功能，聚焦于核心价值，可以快速迭代，降低风险，并有效验证商业模式。",
        "demonstrates_conditions": [
          "S09_F_001",
          "S09_F_003"
        ]
      },
      {
        "case_id": "S09_SUC_003",
        "domain": "数学/力学",
        "case": "无摩擦平面与质点模型",
        "description": "在经典力学中，分析物体运动时常假设物体是质点，且在无摩擦的平面上运动。这使得复杂的物体形状、内部结构以及摩擦力等因素被暂时忽略，从而能用牛顿定律等基本原理分析其运动轨迹和受力情况。",
        "why_this_strategy_worked": "真实世界中的摩擦力、空气阻力、物体形状等因素会使问题变得极其复杂。通过简化，可以专注于核心的运动学和动力学原理，为理解更复杂的系统奠定基础。",
        "demonstrates_conditions": [
          "S09_F_001",
          "S09_F_002"
        ]
      },
      {
        "case_id": "S09_SUC_004",
        "domain": "生物学",
        "case": "孟德尔豌豆杂交实验",
        "description": "孟德尔在研究遗传时，选择了豌豆作为实验材料，并专注于少数几个具有明显对比性状（如高矮、圆皱）的基因，而不是同时研究所有复杂的性状。这使得他能够发现遗传的基本规律。",
        "why_this_strategy_worked": "生物遗传是一个极其复杂的系统。通过选择简单的模型生物和少数几个易于观察和量化的性状，孟德尔成功地将遗传问题简化，从而揭示了基因分离和自由组合的规律。",
        "demonstrates_conditions": [
          "S09_F_001",
          "S09_F_002"
        ]
      }
    ],
    "failures": [
      {
        "case_id": "S09_FAIL_001",
        "domain": "经济学",
        "case": "理性经济人假设的局限性",
        "description": "传统经济学模型常假设人是完全理性的，能够获取所有信息并做出最优决策。然而，在许多现实情境中，人的行为受情绪、认知偏差、信息不对称等非理性因素影响，导致基于该假设的模型预测失准。",
        "why_this_strategy_failed": "“理性经济人”的简化假设在某些情况下移除了对人类行为决策至关重要的复杂因素（如心理、社会因素），导致模型无法准确反映现实，甚至得出错误的政策建议。",
        "demonstrates_conditions": [
