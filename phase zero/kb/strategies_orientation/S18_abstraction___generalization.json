{
  "id": "S18",
  "name": {
    "zh": "抽象化/泛化",
    "en": "Abstraction / Generalization"
  },
  "aliases": [
    "泛化",
    "模式识别",
    "结构提取",
    "概念化"
  ],
  "category": "reasoning",
  "form": "orientation",
  "source_references": [
    {
      "author": "Polya, G.",
      "work": "How to Solve It",
      "year": 1945,
      "chapter": "Looking Back",
      "relevance": "将问题泛化为更一般的问题是波利亚问题解决策略的核心启发式之一。"
    },
    {
      "author": "Mac Lane, S.",
      "work": "Categories for the Working Mathematician",
      "year": 1971,
      "chapter": null,
      "relevance": "范畴论为数学中的抽象化和泛化提供了严格的数学基础，通过函子等概念描述结构保持的映射。"
    }
  ],
  "description": {
    "one_sentence": "追问'这个问题的骨架是什么' — 表面不同的问题可能同根",
    "background": "抽象化/泛化是一种认知策略，旨在通过识别并聚焦于多个具体实例、问题或现象之间的共同属性、关系、模式或结构，从而构建一个更普遍、更简洁的概念、模型或理论。此过程有意识地忽略那些被认为是无关紧要或特定于某个实例的细节，以揭示深层原理或普适规律。其核心目的是简化复杂性，提高理解效率，并使解决方案或理论能够应用于更广泛的场景。",
    "intuitive_analogy": "想象你正在观察一片森林里的各种树木：高大的橡树、笔直的松树、弯曲的柳树。抽象化/泛化就像你忽略了它们具体的树叶形状、树皮颜色、高度等细节，而总结出“树”这个概念，只保留了“有根、有茎、有枝、能光合作用”等核心特征。这个“树”的概念可以适用于所有你见过的和未见过的树木。"
  },
  "trigger": "每次开始解题时，先花一秒跳到抽象层看骨架，再回到细节",
  "attention_priors": [
    "如果我把具体数字/名字/领域全换掉，剩下什么？",
    "这个骨架有名字吗？它属于哪一类问题？",
    "比原题更一般的版本反而可能更容易解 —— 因为细节干扰减少了"
  ],
  "original_wisdom": [
    {
      "source": "Polya 1945 'How to Solve It'",
      "text": "The more general problem may be easier to solve. This is the inventor's paradox."
    }
  ],
