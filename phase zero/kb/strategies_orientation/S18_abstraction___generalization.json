    "failure_modes": [
      {
        "mode_id": "S18_FM_001",
        "description": "过度泛化 (Over-generalization)：抽象模型过于宽泛，包含了不相关的实例，或忽略了关键的区分性特征，导致模型不准确、预测错误或无法有效解决问题。",
        "source": "literature",
        "confidence": 0.9,
        "observed_cases": [
          "S18_FAIL_001",
          "S18_FAIL_002"
        ]
      },
      {
        "mode_id": "S18_FM_002",
        "description": "关键信息丢失 (Loss of Critical Information)：在剔除细节时，错误地将对问题解决至关重要的信息视为无关细节，导致抽象模型无法捕捉到问题的本质或无法解决原问题。",
        "source": "literature",
        "confidence": 0.9,
        "observed_cases": [
          "S18_FAIL_001",
          "S18_FAIL_002"
        ]
      },
      {
        "mode_id": "S18_FM_003",
        "description": "抽象层次不当 (Inappropriate Level of Abstraction)：抽象层次过高则过于空泛，缺乏实用性；抽象层次过低则未能充分简化问题，未能发挥抽象化的优势。",
        "source": "expert_opinion",
        "confidence": 0.8,
        "observed_cases": []
      }
    ]
