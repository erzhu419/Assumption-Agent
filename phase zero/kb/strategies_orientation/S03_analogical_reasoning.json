  "historical_cases": {
    "successes": [
      {
        "case_id": "S03_SUC_001",
        "domain": "物理学/天文学",
        "case": "开普勒行星运动定律",
        "description": "开普勒在研究行星运动时，最初通过类比磁力（当时已知的力）来解释行星围绕太阳的运动。尽管他的磁力类比最终被牛顿的万有引力取代，但这种类比推理帮助他构建了初步的模型并推导出了行星运动的三大定律。",
        "why_this_strategy_worked": "类比提供了一个可操作的框架来解释观测数据，即使初始的物理机制不完全正确，其结构性映射（力导致运动）仍是有效的启发。",
        "demonstrates_conditions": [
          "S03_F_001",
          "S03_F_003"
        ]
      },
      {
        "case_id": "S03_SUC_002",
        "domain": "生物学",
        "case": "DNA双螺旋结构发现",
        "description": "沃森和克里克在构建DNA分子结构模型时，借鉴了X射线衍射数据和化学键合的已知原理。他们通过类比已知的分子结构（如蛋白质的螺旋结构）和配对规则（如碱基互补配对），成功推断出DNA的双螺旋结构。",
        "why_this_strategy_worked": "他们成功地从不同来源的知识中提取了结构性相似性（螺旋形状、配对机制），并将其映射到DNA的未知结构上，最终通过实验验证了这一模型。",
        "demonstrates_conditions": [
          "S03_F_001",
          "S03_F_002",
          "S03_F_003"
        ]
      },
      {
        "case_id": "S03_SUC_003",
        "domain": "物理学",
        "case": "卢瑟福原子模型",
        "description": "卢瑟福在解释α粒子散射实验结果时，通过类比太阳系中行星围绕太阳的运动，提出了原子核周围电子运动的行星模型。这一模型虽然有其局限性，但为现代原子物理学奠定了基础。",
        "why_this_strategy_worked": "太阳系模型提供了一个直观且已知的结构，帮助卢瑟福理解原子内部的电荷分布和粒子运动方式，从而解释了实验现象。",
        "demonstrates_conditions": [
          "S03_F_001",
          "S03_F_003"
        ]
      }
    ],
    "failures": [
      {
        "case_id": "S03_FAIL_001",
        "domain": "物理学",
        "case": "以太理论",
        "description": "19世纪的物理学家为了解释光波的传播，类比水波和声波需要介质，假设存在一种无处不在的“以太”作为光的传播介质。然而，迈克尔逊-莫雷实验证明以太不存在，光的传播并不需要介质。",
        "why_this_strategy_failed": "这种类比是基于表面相似性（波的传播）而忽略了光波与机械波的本质差异（电磁波不需要介质），导致了错误的理论假设。",
        "demonstrates_conditions": [
          "S03_U_001",
          "S03_FM_001"
        ]
      },
      {
        "case_id": "S03_FAIL_002",
        "domain": "医学",
        "case": "放血疗法",
        "description": "在古代和中世纪，医生常通过类比“排毒”或“平衡体液”来治疗疾病，认为放血可以排出“坏血”或恢复体液平衡。这种疗法在许多情况下不仅无效，反而有害，导致病人病情恶化甚至死亡。",
        "why_this_strategy_failed": "这种类比基于对人体生理和疾病机制的错误理解（源领域知识不足），且忽视了放血对身体的负面影响（关键差异被忽视），导致了有害的实践。",
        "demonstrates_conditions": [
          "S03_U_002",
          "S03_U_003",
          "S03_FM_001",
          "S03_FM_002"
        ]
      }
