{
  "id": "S22",
  "name": {
    "zh": "问题重构",
    "en": "Problem Reframing"
  },
  "aliases": [
    "重新定义问题",
    "换框思考",
    "范式转换"
  ],
  "category": "meta_decision",
  "form": "orientation",
  "source_references": [
    {
      "author": "Kuhn, T. S.",
      "work": "The Structure of Scientific Revolutions",
      "year": 1962,
      "chapter": "所有章节",
      "relevance": "提供了范式转换的概念基础，即当旧框架无法解释新现象时，需要全新的理论框架来重构问题和解决方案。"
    },
    {
      "author": "Polya, G.",
      "work": "How to Solve It",
      "year": 1945,
      "chapter": "Look at the unknown; Can you imagine a more accessible related problem?",
      "relevance": "强调了在问题解决过程中，通过改变问题表述、寻找相关问题或简化问题来获得新视角的启发式方法。"
    }
  ],
  "description": {
    "one_sentence": "当解不出时，怀疑问题本身 — 不是答案错，而是'问得不对'",
    "background": "问题重构是一种元认知策略，它认识到在当前问题框架下无法找到有效解决方案时，通过质疑并改变对问题的基本假设、边界、目标或视角来重新定义问题。这通常涉及跳出现有的思维定势，从一个全新的角度审视问题，从而开启新的解决路径。它强调的不是在给定框架内寻找答案，而是改变框架本身，以期发现更深层次的原因或更有效的解决方案。"
  },
  "trigger": "保持这些编译后的觉知在读问题时浮现，不是执行清单",
  "attention_priors": [
    "当发现当前解法陷入僵局或进展缓慢时，问自己：能否将问题中的核心目标或关键约束，用更简洁、更直观的语言重新表述？",
    "如果现有问题描述导致思维受限，问自己：能否通过改变问题的视角或假设，将其转化为一个结构相似但已知条件更明确、更易于求解的子问题？",
    "当尝试多种方法仍无突破时，问自己：能否通过调整问题的“已知”与“未知”部分，使其逻辑关系更紧密，从而揭示潜在的简化路径？",
    "在面对复杂问题时，问自己：能否想象一个与当前问题共享核心挑战，但规模更小、变量更少、更容易验证的“简化版”问题，并尝试解决它以获取洞察？"
  ],
  "original_wisdom": [
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you restate the problem?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you restate it in a different way?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you restate it in your own words?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you imagine a more accessible related problem?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you vary the problem?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you change the data or the unknown, or both if necessary, so that the new unknown and the new data are nearer to each other?"
    }
  ],
