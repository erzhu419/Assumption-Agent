  "category": "reasoning",
  "form": "orientation",
  "source_references": [
    {
      "author": "Polya, G.",
      "work": "How to Solve It",
      "year": 1945,
      "chapter": "Looking Back",
      "relevance": "将问题泛化为更一般的问题是波利亚问题解决策略的核心启发式之一。"
    },
    {
      "author": "Mac Lane, S.",
      "work": "Categories for the Working Mathematician",
      "year": 1971,
      "chapter": null,
      "relevance": "范畴论为数学中的抽象化和泛化提供了严格的数学基础，通过函子等概念描述结构保持的映射。"
    }
  ],
  "description": {
    "one_sentence": "追问'这个问题的骨架是什么' — 表面不同的问题可能同根",
    "background": "抽象化/泛化是一种认知策略，旨在通过识别并聚焦于多个具体实例、问题或现象之间的共同属性、关系、模式或结构，从而构建一个更普遍、更简洁的概念、模型或理论。此过程有意识地忽略那些被认为是无关紧要或特定于某个实例的细节，以揭示深层原理或普适规律。其核心目的是简化复杂性，提高理解效率，并使解决方案或理论能够应用于更广泛的场景。"
  },
  "trigger": "保持这些编译后的觉知在读问题时浮现，不是执行清单",
  "attention_priors": [
    "当发现具体细节阻碍进展时，问自己：如果剥离所有特定数值和上下文，这个问题会呈现出哪种**通用数学或逻辑结构**？",
    "如果当前问题难以直接解决，问自己：是否存在一个**更宽泛的问题类别**，它包含当前问题作为其中一个实例，且该类别中的问题更容易找到通用解法？",
    "当需要验证解法的普适性时，问自己：能否构建一个**更抽象的问题模型**，使得当前问题的解法能直接或通过简单映射应用于该模型，从而涵盖一系列类似情况？",
    "如果陷入特定案例的泥沼，问自己：**哪些核心关系或操作**是这个问题的本质，它们在一个更普遍的框架下会如何表现？"
  ],
  "original_wisdom": [
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you imagine a more general problem?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you solve a more general problem?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Is there a more general problem that is easier to solve?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you find a more general problem that includes your present problem as a special case?"
    },
    {
      "source": "Polya, George, How to Solve It (1945)",
      "text": "Can you generalize the problem?"
    }
  ],
